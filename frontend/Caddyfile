{
	admin off
	auto_https off
}

:8080 {
	@backend path /api /api/* /ws /ws/* /static/avatars /static/avatars/*

	handle @backend {
		reverse_proxy {$BACKEND_UPSTREAM:backend:8080}
	}

	@removedUploads path /uploads /uploads/*

	handle @removedUploads {
		respond 404
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
